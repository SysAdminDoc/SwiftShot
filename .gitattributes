# Normalize line endings: LF for source and docs, CRLF for Windows scripts.
* text=auto
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf
*.iss text eol=crlf
*.spec text eol=lf
*.png binary
*.ico binary
